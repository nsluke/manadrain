{
  "manifest_version": 3,
  "name": "Mana Pool Shopping List",
  "version": "1.0.0",
  "description": "Collect Magic: The Gathering cards from popular MTG sites into a shopping list for Mana Pool.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://manapool.com/*", "https://api.scryfall.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.scryfall.com/*"],
      "js": ["content-scripts/scryfall.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.edhrec.com/*"],
      "js": ["content-scripts/edhrec.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.botbox.dev/*"],
      "js": ["content-scripts/botbox-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.botbox.dev/*"],
      "js": ["content-scripts/botbox.js"],
      "run_at": "document_idle"
    }
  ]
}
